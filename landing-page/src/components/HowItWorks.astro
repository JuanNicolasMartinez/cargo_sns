---
---

<section id="how-it-works" class="hiw relative z-10">
    <div class="hiw__bg"></div>
    <div class="hiw__grain"></div>

    <!-- Header -->
    <div class="hiw__header">
        <p class="hiw__eyebrow" data-i18n="hiw_eyebrow">Tres pasos, cero complicaciones</p>
        <h2 class="hiw__h2">
            <span class="hiw__h2-line" data-i18n="hiw_h2_line1">Así de fácil</span>
            <span class="hiw__h2-line hiw__h2-line--grad" data-i18n="hiw_h2_line2">funciona CargoSnS.</span>
        </h2>
    </div>

    <!-- Cards Row -->
    <div class="hiw__row">

        <!-- Card 1 -->
        <article class="hc" data-hc>
            <div class="hc__inner">
                <!-- Image -->
                <div class="hc__img-box">
                    <img src="https://images.unsplash.com/photo-1553413077-190dd305871c?q=80&w=800&auto=format&fit=crop" alt="Bodega" class="hc__img" loading="lazy"/>
                    <!-- Phase 1 overlay -->
                    <div class="hc__overlay">
                        <div class="hc__overlay-grad"></div>
                        <div class="hc__overlay-text">
                            <h3 class="hc__overlay-title" data-i18n="hiw_card1_title">Publica o Busca</h3>
                            <p class="hc__overlay-sub" data-i18n="hiw_card1_sub">Almacenamiento flexible</p>
                            <div class="hc__overlay-tags">
                                <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> <span data-i18n="hiw_card1_tag1">Cerca de ti</span></span>
                                <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg> <span data-i18n="hiw_card1_tag2">m³ / pallet</span></span>
                            </div>
                        </div>
                    </div>
                    <span class="hc__badge">01</span>
                    <button class="hc__heart hc__heart--img" aria-label="Guardar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></button>
                </div>
                <!-- Phase 2 detail -->
                <div class="hc__detail">
                    <h3 class="hc__detail-title" data-i18n="hiw_card1_title">Publica o Busca</h3>
                    <p class="hc__detail-sub" data-i18n="hiw_card1_sub">Almacenamiento flexible</p>
                    <div class="hc__detail-tags">
                        <span class="hc__tag"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> <span data-i18n="hiw_card1_tag1">Cerca de ti</span></span>
                        <span class="hc__tag"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg> <span data-i18n="hiw_card1_tag2">m³ / pallet</span></span>
                    </div>
                    <p class="hc__detail-desc" data-i18n="hiw_card1_desc">Encuentra bodegas cercanas con precio claro o publica tu espacio libre y monetiza tus m² ociosos.</p>
                    <div class="hc__detail-actions">
                        <button class="hc__btn" data-i18n="hiw_card1_btn">Explorar bodegas</button>
                        <button class="hc__heart hc__heart--btn" aria-label="Guardar" data-i18n-aria="hiw_save"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></button>
                    </div>
                </div>
            </div>
        </article>

        <!-- Card 2 -->
        <article class="hc" data-hc>
            <div class="hc__inner">
                <div class="hc__img-box">
                    <img src="https://images.unsplash.com/photo-1580674285054-bed31e145f59?q=80&w=800&auto=format&fit=crop" alt="Transporte" class="hc__img" loading="lazy"/>
                    <div class="hc__overlay">
                        <div class="hc__overlay-grad"></div>
                        <div class="hc__overlay-text">
                            <h3 class="hc__overlay-title" data-i18n="hiw_card2_title">Coordina Transporte</h3>
                            <p class="hc__overlay-sub" data-i18n="hiw_card2_sub">Logística verificada</p>
                            <div class="hc__overlay-tags">
                                <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <span data-i18n="hiw_card2_tag1">Tiempo real</span></span>
                                <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> <span data-i18n="hiw_card2_tag2">Verificado</span></span>
                            </div>
                        </div>
                    </div>
                    <span class="hc__badge">02</span>
                    <button class="hc__heart hc__heart--img" aria-label="Guardar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></button>
                </div>
                <div class="hc__detail">
                    <h3 class="hc__detail-title" data-i18n="hiw_card2_title">Coordina Transporte</h3>
                    <p class="hc__detail-sub" data-i18n="hiw_card2_sub">Logística verificada</p>
                    <div class="hc__detail-tags">
                        <span class="hc__tag"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <span data-i18n="hiw_card2_tag1">Tiempo real</span></span>
                        <span class="hc__tag"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> <span data-i18n="hiw_card2_tag2">Verificado</span></span>
                    </div>
                    <p class="hc__detail-desc" data-i18n="hiw_card2_desc">Conecta con transportistas verificados. Evidencia fotográfica de recogida y entrega con rastreo en vivo.</p>
                    <div class="hc__detail-actions">
                        <button class="hc__btn hc__btn--accent" data-i18n="hiw_card2_btn">Ver transportes</button>
                        <button class="hc__heart hc__heart--btn" aria-label="Guardar"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></button>
                    </div>
                </div>
            </div>
        </article>

        <!-- Card 3 -->
        <article class="hc" data-hc>
            <div class="hc__inner">
                <div class="hc__img-box">
                    <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=800&auto=format&fit=crop" alt="Dashboard" class="hc__img" loading="lazy"/>
                    <div class="hc__overlay">
                        <div class="hc__overlay-grad"></div>
                        <div class="hc__overlay-text">
                            <h3 class="hc__overlay-title" data-i18n="hiw_card3_title">Gestiona y Crece</h3>
                            <p class="hc__overlay-sub" data-i18n="hiw_card3_sub">Control total</p>
                            <div class="hc__overlay-tags">
                                <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg> <span data-i18n="hiw_card3_tag1">Dashboard</span></span>
                                <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg> <span data-i18n="hiw_card3_tag2">Analítica</span></span>
                            </div>
                        </div>
                    </div>
                    <span class="hc__badge">03</span>
                    <button class="hc__heart hc__heart--img" aria-label="Guardar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></button>
                </div>
                <div class="hc__detail">
                    <h3 class="hc__detail-title" data-i18n="hiw_card3_title">Gestiona y Crece</h3>
                    <p class="hc__detail-sub" data-i18n="hiw_card3_sub">Control total</p>
                    <div class="hc__detail-tags">
                        <span class="hc__tag"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg> <span data-i18n="hiw_card3_tag1">Dashboard</span></span>
                        <span class="hc__tag"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg> <span data-i18n="hiw_card3_tag2">Analítica</span></span>
                    </div>
                    <p class="hc__detail-desc" data-i18n="hiw_card3_desc">Inventario, pagos, reputación y pricing sugerido. Sube de nivel con nuestro sistema de gamificación.</p>
                    <div class="hc__detail-actions">
                        <button class="hc__btn" data-i18n="hiw_card3_btn">Conocer el dashboard</button>
                        <button class="hc__heart hc__heart--btn" aria-label="Guardar"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></button>
                    </div>
                </div>
            </div>
        </article>

    </div>
</section>

<style>
    /* ═══ THEME ═══ */
    .hiw {
        --bg: #f8fafc;
        --bg-r1: rgba(59,130,246,0.04);
        --bg-r2: rgba(99,102,241,0.03);
        --grain: 0.04;
        --ey: #94a3b8;
        --h: #0f172a;
        --c-bg: #fff;
        --c-brd: rgba(0,0,0,0.08);
        --c-sh: 0 4px 20px rgba(0,0,0,0.06);
        --c-sh-up: 0 20px 50px rgba(0,0,0,0.12), 0 8px 20px rgba(0,0,0,0.06);
        --c-title: #0f172a;
        --c-sub: #94a3b8;
        --c-desc: #64748b;
        --c-tag-bg: rgba(0,0,0,0.04);
        --c-tag-c: #475569;
        --c-tag-ic: #94a3b8;
        --c-btn-bg: #f1f5f9;
        --c-btn-c: #0f172a;
        --c-btn-h: #e2e8f0;
        --c-btn-a: #0f172a;
        --c-btn-ac: #fff;
        --c-btn-ah: #1e293b;
        --c-fav-bg: rgba(0,0,0,0.04);
        --c-fav-c: #94a3b8;
    }
    :global(.dark) .hiw {
        --bg: #0f172b;
        --bg-r1: rgba(59,130,246,0.06);
        --bg-r2: rgba(99,102,241,0.04);
        --grain: 0.06;
        --ey: rgba(255,255,255,0.3);
        --h: #fff;
        --c-bg: rgba(255,255,255,0.05);
        --c-brd: rgba(255,255,255,0.08);
        --c-sh: 0 4px 20px rgba(0,0,0,0.2);
        --c-sh-up: 0 20px 50px rgba(0,0,0,0.3), 0 8px 20px rgba(0,0,0,0.15);
        --c-title: #f1f5f9;
        --c-sub: rgba(255,255,255,0.4);
        --c-desc: rgba(255,255,255,0.45);
        --c-tag-bg: rgba(255,255,255,0.06);
        --c-tag-c: rgba(255,255,255,0.55);
        --c-tag-ic: rgba(255,255,255,0.35);
        --c-btn-bg: rgba(255,255,255,0.08);
        --c-btn-c: #f1f5f9;
        --c-btn-h: rgba(255,255,255,0.14);
        --c-btn-a: #3b82f6;
        --c-btn-ac: #fff;
        --c-btn-ah: #2563eb;
        --c-fav-bg: rgba(255,255,255,0.06);
        --c-fav-c: rgba(255,255,255,0.4);
    }

    /* ═══ SECTION ═══ */
    .hiw {
        position: relative; overflow: hidden;
        padding: 6rem 1.25rem 5rem;
    }
    @media (min-width: 768px) { .hiw { padding: 8rem 2rem 6rem; } }

    .hiw__bg {
        position: absolute; inset: 0; z-index: 0;
        background:
            radial-gradient(ellipse 70% 50% at 20% 0%, var(--bg-r1), transparent),
            radial-gradient(ellipse 60% 40% at 80% 100%, var(--bg-r2), transparent),
            var(--bg);
    }
    .hiw__grain {
        position: absolute; inset: 0; z-index: 1;
        opacity: var(--grain);
        background-image: url('https://grainy-gradients.vercel.app/noise.svg');
    }

    /* ═══ HEADER ═══ */
    .hiw__header {
        position: relative; z-index: 10;
        text-align: center;
        margin-bottom: 3.5rem;
    }
    @media (min-width: 768px) { .hiw__header { margin-bottom: 4.5rem; } }

    .hiw__eyebrow {
        font-size: 0.9rem; font-weight: 700;
        letter-spacing: 0.22em; text-transform: uppercase;
        color: var(--ey); margin-bottom: 1.25rem;
    }
    .hiw__h2 { display: flex; flex-direction: column; gap: 0.1em; }
    .hiw__h2-line {
        font-size: clamp(2.6rem, 6vw, 5rem);
        font-weight: 900; letter-spacing: -0.04em; line-height: 1.05;
        color: var(--h);
    }
    .hiw__h2-line--grad {
        background: linear-gradient(90deg, #2060c6, #2737e1, #3b46e8);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* ═══ ROW ═══ */
    .hiw__row {
        position: relative; z-index: 10;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 1.25rem;
        flex-wrap: wrap;
        max-width: 1100px;
        margin: 0 auto;
    }
    @media (min-width: 1024px) {
        .hiw__row { flex-wrap: nowrap; gap: 1.5rem; align-items: center; }
    }

    /* ═══════════════════════════════
       CARD — PHASE 1 (default)
       Full-bleed image, overlay text
    ═══════════════════════════════ */
    .hc {
        width: 320px;
        max-width: 85vw;
        flex-shrink: 0;
        border-radius: 1.5rem;
        background: var(--c-bg);
        border: 1px solid var(--c-brd);
        box-shadow: var(--c-sh);
        overflow: hidden;
        /* Entrance start state */
        opacity: 0;
        transform: translateY(40px) scale(0.96);
        /* ALL transitions happen via CSS */
        transition:
            transform 0.7s cubic-bezier(0.22, 1, 0.36, 1),
            box-shadow 0.7s cubic-bezier(0.22, 1, 0.36, 1),
            opacity 0.7s ease;
    }
    @media (min-width: 768px) { .hc { width: 340px; } }

    .hc__inner {
        transition: padding 0.7s cubic-bezier(0.22, 1, 0.36, 1);
        padding: 0;
    }

    /* Image box */
    .hc__img-box {
        position: relative;
        width: 100%;
        aspect-ratio: 3 / 4;
        overflow: hidden;
        border-radius: 0;
        transition: border-radius 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                    aspect-ratio 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .hc__img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* Phase 1 overlay */
    .hc__overlay {
        position: absolute; inset: 0; z-index: 2;
        display: flex; flex-direction: column; justify-content: flex-end;
        transition: opacity 0.5s ease;
    }
    .hc__overlay-grad {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.25) 40%, transparent 65%);
    }
    .hc__overlay-text {
        position: relative; z-index: 1;
        padding: 1.5rem;
    }
    .hc__overlay-title {
        font-size: 1.75rem; font-weight: 800; color: #fff;
        letter-spacing: -0.02em; margin-bottom: 0.1rem;
    }
    .hc__overlay-sub {
        font-size: 0.9rem; color: rgba(255,255,255,0.55);
        margin-bottom: 0.7rem;
    }
    .hc__overlay-tags { display: flex; gap: 0.9rem; }
    .hc__overlay-tags span {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.65);
    }
    .hc__overlay-tags svg { color: rgba(255,255,255,0.45); }

    .hc__badge {
        position: absolute; top: 0.75rem; left: 0.75rem; z-index: 5;
        font-size: 0.68rem; font-weight: 800; letter-spacing: 0.06em;
        color: rgba(255,255,255,0.7);
        background: rgba(0,0,0,0.3); backdrop-filter: blur(6px);
        padding: 0.22rem 0.5rem; border-radius: 7px;
    }
    .hc__heart--img {
        position: absolute; top: 0.75rem; right: 0.75rem; z-index: 5;
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 50%; border: none; cursor: pointer;
        background: rgba(255,255,255,0.2); backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.65);
        transition: color 0.3s, background 0.3s, opacity 0.5s;
    }
    .hc__heart--img:hover { color: #ef4444; background: rgba(255,255,255,0.4); }

    /* Phase 2 detail — collapsed by default */
    .hc__detail {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        padding: 0 1.25rem;
        transition:
            max-height 0.7s cubic-bezier(0.22, 1, 0.36, 1),
            opacity 0.5s ease 0.1s,
            padding 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .hc__detail-title {
        font-size: 1.4rem; font-weight: 800; color: var(--c-title);
        letter-spacing: -0.02em; margin-bottom: 0.05rem; padding-top: 1rem;
    }
    .hc__detail-sub {
        font-size: 0.88rem; color: var(--c-sub); margin-bottom: 0.6rem;
    }
    .hc__detail-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.6rem; }
    .hc__tag {
        display: inline-flex; align-items: center; gap: 0.25rem;
        font-size: 0.78rem; font-weight: 600;
        color: var(--c-tag-c); background: var(--c-tag-bg);
        padding: 0.25rem 0.5rem; border-radius: 6px;
    }
    .hc__tag svg { color: var(--c-tag-ic); flex-shrink: 0; }
    .hc__detail-desc {
        font-size: 0.9rem; line-height: 1.6; color: var(--c-desc);
        margin-bottom: 1rem;
    }
    .hc__detail-actions {
        display: flex; gap: 0.5rem; padding-bottom: 1.25rem;
    }
    .hc__btn {
        flex: 1; padding: 0.72rem 1rem;
        border: none; border-radius: 100px;
        font-size: 0.9rem; font-weight: 700; cursor: pointer;
        background: var(--c-btn-bg); color: var(--c-btn-c);
        transition: background 0.3s, transform 0.3s;
    }
    .hc__btn:hover { background: var(--c-btn-h); transform: translateY(-1px); }
    .hc__btn--accent { background: var(--c-btn-a); color: var(--c-btn-ac); }
    .hc__btn--accent:hover { background: var(--c-btn-ah); }
    .hc__heart--btn {
        width: 42px; height: 42px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        border-radius: 50%; border: 1.5px solid var(--c-brd);
        background: transparent; color: var(--c-fav-c); cursor: pointer;
        transition: color 0.3s, border-color 0.3s;
    }
    .hc__heart--btn:hover { color: #ef4444; border-color: #ef4444; }

    /* ═══════════════════════════════
       CARD — ENTRANCE (.is-visible)
    ═══════════════════════════════ */
    .hc.is-visible {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    /* ═══════════════════════════════
       CARD — PHASE 2 (.is-open)
       Image shrinks, detail reveals
    ═══════════════════════════════ */
    .hc.is-visible.is-open {
        transform: translateY(0) scale(1.05);
        box-shadow: var(--c-sh-up);
        z-index: 20;
    }
    .hc.is-open .hc__inner {
        padding: 10px;
    }
    .hc.is-open .hc__img-box {
        aspect-ratio: 4 / 3;
        border-radius: 1rem;
    }
    .hc.is-open .hc__img {
        transform: translateY(-8%) scale(1.08);
    }
    .hc.is-open .hc__overlay {
        opacity: 0;
        pointer-events: none;
    }
    .hc.is-open .hc__heart--img {
        opacity: 0;
        pointer-events: none;
    }
    .hc.is-open .hc__detail {
        max-height: 300px;
        opacity: 1;
        padding: 0 1.25rem;
    }

    /* Siblings shrink when one is open */
    .hc.is-visible.is-sibling {
        transform: translateY(0) scale(0.92);
        opacity: 0.55;
    }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 640px) {
        .hc { width: 290px; }
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const cards = document.querySelectorAll<HTMLElement>("[data-hc]");

    /*  Each card gets its own ScrollTrigger.
        When the card enters the "sweet spot" (center of viewport),
        it gets .is-open and siblings get .is-sibling.
        When it leaves, classes are removed.
        No GSAP animation — just CSS classes = bulletproof with Lenis.
    */
    cards.forEach((card, i) => {
        ScrollTrigger.create({
            trigger: card,
            start: "top 55%",
            end: "bottom 45%",
            onEnter: () => activate(i),
            onEnterBack: () => activate(i),
            onLeave: () => deactivate(i),
            onLeaveBack: () => deactivate(i),
        });
    });

    function activate(index: number) {
        cards.forEach((c, i) => {
            if (i === index) {
                c.classList.add("is-open");
                c.classList.remove("is-sibling");
            } else {
                c.classList.remove("is-open");
                c.classList.add("is-sibling");
            }
        });
    }

    function deactivate(index: number) {
        // Only deactivate if this card was the open one
        const card = cards[index];
        if (card.classList.contains("is-open")) {
            cards.forEach((c) => {
                c.classList.remove("is-open");
                c.classList.remove("is-sibling");
            });
        }
    }

    /* ── Header entrance ── */
    gsap.fromTo(".hiw__eyebrow",
        { opacity: 0, y: 15 },
        {
            opacity: 1, y: 0,
            duration: 0.6, ease: "power3.out",
            scrollTrigger: {
                trigger: "#how-it-works",
                start: "top 85%",
                toggleActions: "play none none reverse",
            },
        }
    );
    gsap.fromTo(".hiw__h2-line",
        { opacity: 0, y: 40 },
        {
            opacity: 1, y: 0,
            duration: 0.8, stagger: 0.12, ease: "power4.out",
            scrollTrigger: {
                trigger: "#how-it-works",
                start: "top 83%",
                toggleActions: "play none none reverse",
            },
        }
    );

    /* ── Cards entrance — IntersectionObserver (no GSAP, no conflicts) ── */
    const row = document.querySelector(".hiw__row");
    if (row) {
        const io = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    cards.forEach((c, i) => {
                        setTimeout(() => {
                            c.classList.add("is-visible");
                        }, i * 120);
                    });
                    io.disconnect();
                }
            });
        }, { threshold: 0.1 });
        io.observe(row);
    }
</script>
