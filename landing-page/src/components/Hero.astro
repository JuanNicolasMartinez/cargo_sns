<style>
    /* ── Phone video wrapper ───────────────────────────── */
    .hero-phone-wrap {
        width: 780px;
        max-width: 95%;
        position: relative;
        display: flex;
        flex-direction: column;
        max-height: 100%;
        isolation: isolate;
    }

    /*
     * ── DARK-MODE: soft radial mask ─────────────────────
     * Feathers ALL edges of the video so the background
     * color mismatch dissolves into the page.
     * The ellipse is tall (95% height) to keep the phone
     * and hands fully visible, but fades the outer edges.
     *
     * TUNING:
     *   - First % pair = ellipse width/height
     *   - "at 50% 42%" = center of the ellipse (slightly up
     *     to keep the top of the phone sharp)
     *   - "black 55%" = fully visible core area
     *   - "transparent 100%" = fully gone at edge
     *
     * If too much hand is cut: increase the first %s or
     * increase "black 55%" toward "black 65%"
     */
    :global(.dark) .hero-phone-wrap {
        -webkit-mask-image:
            radial-gradient(
                ellipse 75% 85% at 50% 42%,
                black 55%,
                transparent 100%
            );
        mask-image:
            radial-gradient(
                ellipse 75% 85% at 50% 42%,
                black 55%,
                transparent 100%
            );
    }

    .hero-phone-canvas {
        width: 100%;
        height: 100%;
        max-height: calc(100vh - 420px);
        object-fit: contain;
        display: block;
        position: relative;
        z-index: 2;
    }

    /* Light mode: multiply removes white bg */
    #hero-video-light {
        mix-blend-mode: multiply;
    }

    /*
     * Dark mode video:
     *   – screen blend makes the darkest pixels disappear
     *     into whatever is behind (your page bg)
     *   – contrast+brightness push the video bg toward
     *     pure black so screen can eliminate it better
     *   – the radial mask handles the edges
     *
     * TUNING:
     *   - If the video content looks washed out:
     *     lower brightness (e.g. 1.05)
     *   - If bg rectangle is still visible:
     *     raise contrast (e.g. 1.5)
     */
    #hero-video-dark {
        mix-blend-mode: screen;
        filter: contrast(1.4) brightness(1.1);
    }

    /* Bottom fade */
    .hero-phone-bottom-fade {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 38%;
        z-index: 3;
        pointer-events: none;
    }
    :global(.dark) .hero-phone-bottom-fade {
        background: linear-gradient(to bottom, transparent, #0f172a);
    }

    /* Floating orbs */
    .hero-phone-orb {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        z-index: 1;
        filter: blur(50px);
        opacity: 0.45;
    }
    .hero-phone-orb--left {
        width: 200px;
        height: 120px;
        bottom: 8%;
        left: 10%;
        background: radial-gradient(ellipse, #1F6AE1 0%, transparent 70%);
        animation: orbFloat 5s ease-in-out infinite;
    }
    .hero-phone-orb--right {
        width: 160px;
        height: 100px;
        bottom: 4%;
        right: 12%;
        background: radial-gradient(ellipse, #A9C9FF 0%, transparent 70%);
        animation: orbFloat 6s ease-in-out infinite reverse;
    }
    @keyframes orbFloat {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-12px); }
    }

    .hero-phone-reflection {
        position: absolute;
        bottom: 14%;
        left: 25%;
        right: 25%;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(169,201,255,0.3), transparent);
        z-index: 4;
        pointer-events: none;
    }

    /* ── Backdrop ───────────────────────────────────────── */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1000;
        background: rgba(10, 37, 64, 0.45);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s ease;
    }
    .modal-backdrop.is-open {
        opacity: 1;
        pointer-events: auto;
    }

    /* ── Modal wrapper ──────────────────────────────────── */
    .hero-modal {
        position: fixed;
        inset: 0;
        z-index: 1001;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }
    .hero-modal.is-open {
        pointer-events: auto;
    }

    /* ── Bubble card ────────────────────────────────────── */
    .modal-bubble {
        position: relative;
        width: min(440px, 92vw);
        background: white;
        border-radius: 28px;
        padding: 2.5rem 2rem 2rem;
        box-shadow:
            0 0 0 1px rgba(0,0,0,0.06),
            0 24px 60px rgba(10, 37, 64, 0.18),
            0 8px 20px rgba(10, 37, 64, 0.1);
        transform: scale(0.72) translateY(24px);
        opacity: 0;
        transform-origin: center bottom;
        transition:
            transform 0.45s cubic-bezier(0.34, 1.42, 0.64, 1),
            opacity   0.3s  ease;
        text-align: center;
    }
    :global(.dark) .modal-bubble {
        background: #0f172a;
        box-shadow:
            0 0 0 1px rgba(255,255,255,0.07),
            0 24px 60px rgba(0,0,0,0.5),
            0 8px 20px rgba(0,0,0,0.3);
    }
    .hero-modal.is-open .modal-bubble {
        transform: scale(1) translateY(0);
        opacity: 1;
    }

    /* ── Orbiting bubbles (decorative) ─────────────────── */
    .modal-bubble::before,
    .modal-bubble::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        transition: transform 0.45s cubic-bezier(0.34, 1.42, 0.64, 1), opacity 0.3s ease;
        opacity: 0;
    }
    .modal-bubble::before {
        width: 80px; height: 80px;
        background: radial-gradient(circle, var(--bubble-color, #1F6AE1) 0%, transparent 70%);
        top: -30px; right: -20px;
        transform: scale(0);
    }
    .modal-bubble::after {
        width: 50px; height: 50px;
        background: radial-gradient(circle, var(--bubble-color, #A9C9FF) 0%, transparent 70%);
        bottom: -18px; left: -10px;
        transform: scale(0);
    }
    .hero-modal.is-open .modal-bubble::before,
    .hero-modal.is-open .modal-bubble::after {
        transform: scale(1);
        opacity: 0.5;
    }

    /* ── Close button ───────────────────────────────────── */
    .modal-close {
        position: absolute;
        top: 1rem; right: 1rem;
        width: 32px; height: 32px;
        border-radius: 50%;
        border: none;
        background: rgba(0,0,0,0.06);
        color: #64748b;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
    }
    .modal-close:hover {
        background: rgba(0,0,0,0.12);
        transform: rotate(90deg);
    }
    :global(.dark) .modal-close {
        background: rgba(255,255,255,0.08);
        color: #94a3b8;
    }

    /* ── Icon ───────────────────────────────────────────── */
    .modal-icon {
        width: 64px; height: 64px;
        border-radius: 20px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.25rem;
    }

    /* ── Text ───────────────────────────────────────────── */
    .modal-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #0A2540;
        margin: 0 0 0.5rem;
    }
    :global(.dark) .modal-title { color: #fff; }

    .modal-desc {
        font-size: 0.9rem;
        color: #64748b;
        line-height: 1.6;
        margin: 0 0 1.75rem;
    }
    :global(.dark) .modal-desc { color: #94a3b8; }

    /* ── Store buttons ──────────────────────────────────── */
    .modal-store-btns {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
    }
    .store-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0.65rem 1.1rem;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        min-width: 150px;
    }
    .store-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }
    .store-btn--apple {
        background: #000;
        color: #fff;
    }
    .store-btn--google {
        background: #fff;
        color: #000;
        border: 1px solid #e2e8f0;
    }
    :global(.dark) .store-btn--google {
        background: #1e293b;
        color: #fff;
        border-color: #334155;
    }
    .store-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 400;
        opacity: 0.75;
        line-height: 1;
    }
    .store-name {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.3;
    }

    /* ── Divider ─────────────────────────────────────────── */
    .modal-divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1.25rem 0 1rem;
        color: #cbd5e1;
        font-size: 0.8rem;
    }
    .modal-divider::before,
    .modal-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e2e8f0;
    }
    :global(.dark) .modal-divider::before,
    :global(.dark) .modal-divider::after { background: #1e293b; }

    /* ── Web CTA ─────────────────────────────────────────── */
    .modal-web-btn {
        display: block;
        width: 100%;
        padding: 0.85rem;
        background: linear-gradient(135deg, #1F6AE1, #A9C9FF);
        color: #fff;
        font-weight: 700;
        font-size: 0.95rem;
        border-radius: 14px;
        text-decoration: none;
        transition: opacity 0.2s, transform 0.2s;
    }
    .modal-web-btn:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }
</style>

<script>
    import { gsap } from "gsap";

    // ── Theme-aware video swap ────────────────────────────
    const videoLight = document.getElementById("hero-video-light") as HTMLVideoElement;
    const videoDark  = document.getElementById("hero-video-dark")  as HTMLVideoElement;

    let currentTheme: boolean | null = null;

    function applyThemeVideo(animate: boolean) {
        const isDark = document.documentElement.classList.contains("dark");
        const incoming = isDark ? videoDark  : videoLight;
        const outgoing = isDark ? videoLight : videoDark;

        outgoing.style.display = "none";
        incoming.style.display = "block";
        if (incoming.paused) incoming.play();

        if (animate) {
            gsap.fromTo(incoming,
                { opacity: 0, y: 60 },
                { opacity: 1, y: 0, duration: 1.2, ease: "power3.out", delay: 0.3 }
            );
        }
    }

    // Init without animation
    currentTheme = document.documentElement.classList.contains("dark");
    applyThemeVideo(false);

    new MutationObserver(() => {
        const isDark = document.documentElement.classList.contains("dark");
        if (isDark === currentTheme) return; // class changed but theme didn't
        currentTheme = isDark;
        applyThemeVideo(true);
    }).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
    });

    // Hero Animations
    const tl = gsap.timeline();

    tl.from("#hero-content > *", {
        y: 50,
        opacity: 0,
        duration: 1,
        stagger: 0.1,
        ease: "power3.out",
    }).from(
        "#hero-visual",
        {
            x: 50,
            opacity: 0,
            duration: 1.2,
            ease: "power3.out",
        },
        "-=0.8",
    );

    // ── Chroma key: remove green background from phone video ─────────
    const phoneVideo  = document.getElementById("hero-phone-video-src") as HTMLVideoElement;
    const phoneCanvas = document.getElementById("hero-phone-canvas")    as HTMLCanvasElement;

    if (phoneVideo && phoneCanvas) {
        const ctx = phoneCanvas.getContext("2d", { willReadFrequently: true })!;
        let chromaRunning = false;

        let boomerangDir  = 1;
        const PLAYBACK_SPEED = 1.5;
        let lastTimestamp = 0;

        function drawChromaFrame(timestamp: number) {
            if (!phoneVideo.videoWidth || !phoneVideo.videoHeight) {
                requestAnimationFrame(drawChromaFrame);
                return;
            }

            if (phoneCanvas.width !== phoneVideo.videoWidth) {
                phoneCanvas.width  = phoneVideo.videoWidth;
                phoneCanvas.height = phoneVideo.videoHeight;
            }

            if (lastTimestamp) {
                const delta = (timestamp - lastTimestamp) / 1000;
                let next = phoneVideo.currentTime + boomerangDir * PLAYBACK_SPEED * delta;

                if (next >= phoneVideo.duration) {
                    next = phoneVideo.duration;
                    boomerangDir = -1;
                } else if (next <= 0) {
                    next = 0;
                    boomerangDir = 1;
                }
                phoneVideo.currentTime = next;
            }
            lastTimestamp = timestamp;

            ctx.drawImage(phoneVideo, 0, 0);
            const frame = ctx.getImageData(0, 0, phoneCanvas.width, phoneCanvas.height);
            const d = frame.data;

            for (let i = 0; i < d.length; i += 4) {
                const r = d[i], g = d[i + 1], b = d[i + 2];
                const isGreen = g > 80 && g > r * 1.25 && g > b * 1.15;
                if (isGreen) d[i + 3] = 0;
            }

            ctx.putImageData(frame, 0, 0);
            requestAnimationFrame(drawChromaFrame);
        }

        function startChroma() {
            if (chromaRunning) return;
            chromaRunning = true;
            phoneVideo.pause();
            phoneVideo.currentTime = 0;
            requestAnimationFrame(drawChromaFrame);
        }

        if (phoneVideo.readyState >= 1) {
            startChroma();
        } else {
            phoneVideo.addEventListener("loadedmetadata", startChroma, { once: true });
        }
        phoneVideo.load();
    }

    // ── Mount modals at body level (escape overflow:hidden) ──────────
    const template = document.getElementById("hero-modals-template") as HTMLTemplateElement;
    document.body.appendChild(template.content.cloneNode(true));

    const backdrop = document.getElementById("hero-modal-backdrop")!;
    let activeModal: HTMLElement | null = null;
    let scrollY = 0;

    function lockScroll() {
        scrollY = window.scrollY;
        document.body.style.position = "fixed";
        document.body.style.top      = `-${scrollY}px`;
        document.body.style.left     = "0";
        document.body.style.right    = "0";
        document.body.style.overflow = "hidden";
        (window as any).__lenis?.stop?.();
    }

    function unlockScroll() {
        document.body.style.position = "";
        document.body.style.top      = "";
        document.body.style.left     = "";
        document.body.style.right    = "";
        document.body.style.overflow = "";
        window.scrollTo({ top: scrollY, behavior: "instant" });
        (window as any).__lenis?.start?.();
    }

    function openModal(id: string, originBtn: HTMLElement) {
        const modal = document.getElementById(`modal-${id}`);
        if (!modal) return;

        const btnRect = originBtn.getBoundingClientRect();
        const bubbleEl = modal.querySelector(".modal-bubble") as HTMLElement;
        const bx = btnRect.left + btnRect.width  / 2;
        const by = btnRect.top  + btnRect.height / 2;
        const ox = ((bx / window.innerWidth)  * 100).toFixed(1);
        const oy = ((by / window.innerHeight) * 100).toFixed(1);
        bubbleEl.style.transformOrigin = `${ox}% ${oy}%`;

        lockScroll();
        backdrop.classList.add("is-open");
        modal.classList.add("is-open");
        activeModal = modal;
    }

    function closeModal() {
        if (!activeModal) return;
        activeModal.classList.remove("is-open");
        backdrop.classList.remove("is-open");
        unlockScroll();
        activeModal = null;
    }

    document.querySelectorAll<HTMLButtonElement>(".hero-cta-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            const id = btn.dataset.modal;
            if (id) openModal(id, btn);
        });
    });

    backdrop.addEventListener("click", closeModal);
    document.querySelectorAll(".modal-close").forEach(btn =>
        btn.addEventListener("click", closeModal)
    );

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
    });
</script>