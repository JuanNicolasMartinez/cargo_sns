---
import { Menu, Sun, Moon } from "lucide-astro";
---

<nav
    class="fixed top-0 left-0 w-full z-50 transition-all duration-300"
    id="navbar"
>
    <div
        class="absolute inset-0 bg-white/10 dark:bg-slate-900/10 backdrop-blur-md border-b border-white/20 dark:border-white/10 shadow-sm opacity-0"
        id="nav-bg"
    >
    </div>
    <div
        class="container mx-auto px-6 py-4 relative flex justify-between items-center"
    >
        <a
            href="/"
            class="text-2xl font-bold text-brand-dark dark:text-white flex items-center gap-2"
        >
            <img
                src="/logo-CargoSns-removebg.png"
                alt="CargoSnS Logo"
                class="h-10 w-auto"
            />
        </a>

        <div class="hidden md:flex items-center space-x-8">
        </div>

        <div class="hidden md:flex items-center space-x-4">
            <!-- Language Toggle -->
            <div class="relative" id="lang-menu-wrapper">
                <button
                    id="lang-toggle"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-semibold text-brand-dark dark:text-white hover:bg-black/5 dark:hover:bg-white/10 transition-colors focus:outline-none"
                    aria-label="Change language"
                >
                    <span id="lang-flag" class="text-base">🇪🇸</span>
                    <span id="lang-code" class="uppercase tracking-wide">ES</span>
                    <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div
                    id="lang-dropdown"
                    class="absolute right-0 top-full mt-2 w-36 bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700 rounded-2xl shadow-xl overflow-hidden opacity-0 pointer-events-none scale-95 origin-top-right transition-all duration-200"
                >
                    <button data-lang="es" class="lang-option w-full flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium text-brand-dark dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                        <span>🇪🇸</span> Español
                    </button>
                    <button data-lang="en" class="lang-option w-full flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium text-brand-dark dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                        <span>🇬🇧</span> English
                    </button>
                    <button data-lang="de" class="lang-option w-full flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium text-brand-dark dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                        <span>🇩🇪</span> Deutsch
                    </button>
                </div>
            </div>

            <button
                id="theme-toggle"
                class="p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/10 transition-colors focus:outline-none"
                aria-label="Toggle Dark Mode"
            >
                <Sun class="w-5 h-5 hidden dark:block text-yellow-400" />
                <Moon class="w-5 h-5 block dark:hidden text-brand-dark" />
            </button>
            <a
                href="#"
                class="font-semibold text-brand-dark dark:text-white hover:text-brand-primary transition-colors"
                data-i18n="nav_login"
                >Iniciar Sesión</a
            >
            <a
                href="#"
                class="px-5 py-2.5 bg-brand-primary hover:bg-brand-dark text-white font-semibold rounded-full shadow-lg shadow-brand-primary/20 transition-all transform hover:scale-105"
                data-i18n="nav_cta"
            >
                Empezar Ahora
            </a>
        </div>

        <div class="md:hidden flex items-center gap-3">
            <!-- Language toggle mobile -->
            <div class="relative" id="lang-menu-wrapper-mobile">
                <button
                    id="lang-toggle-mobile"
                    class="flex items-center gap-1 px-2 py-1.5 rounded-full text-sm font-semibold text-brand-dark dark:text-white hover:bg-black/5 dark:hover:bg-white/10 transition-colors focus:outline-none"
                    aria-label="Change language"
                >
                    <span id="lang-flag-mobile" class="text-base">🇪🇸</span>
                    <span id="lang-code-mobile" class="uppercase tracking-wide text-xs">ES</span>
                </button>
                <div
                    id="lang-dropdown-mobile"
                    class="absolute right-0 top-full mt-2 w-36 bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700 rounded-2xl shadow-xl overflow-hidden opacity-0 pointer-events-none scale-95 origin-top-right transition-all duration-200"
                >
                    <button data-lang="es" class="lang-option-mobile w-full flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium text-brand-dark dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                        <span>🇪🇸</span> Español
                    </button>
                    <button data-lang="en" class="lang-option-mobile w-full flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium text-brand-dark dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                        <span>🇬🇧</span> English
                    </button>
                    <button data-lang="de" class="lang-option-mobile w-full flex items-center gap-2.5 px-4 py-2.5 text-sm font-medium text-brand-dark dark:text-white hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                        <span>🇩🇪</span> Deutsch
                    </button>
                </div>
            </div>

            <button
                id="theme-toggle-mobile"
                class="p-2 rounded-full hover:bg-black/5 dark:hover:bg-white/10 transition-colors focus:outline-none"
                aria-label="Toggle Dark Mode"
            >
                <Sun class="w-5 h-5 hidden dark:block text-yellow-400" />
                <Moon class="w-5 h-5 block dark:hidden text-brand-dark dark:text-white" />
            </button>
            <button class="text-brand-dark dark:text-white focus:outline-none">
                <Menu class="w-8 h-8" />
            </button>
        </div>
    </div>
</nav>

<script>
    // Navbar scroll effect
    const navBg = document.getElementById("nav-bg");
    const navbar = document.getElementById("navbar");

    window.addEventListener("scroll", () => {
        if (window.scrollY > 20) {
            navBg?.classList.remove("opacity-0");
            navbar?.classList.add("py-2");
            navbar?.classList.remove("py-4");
        } else {
            navBg?.classList.add("opacity-0");
            navbar?.classList.remove("py-2");
            navbar?.classList.add("py-4");
        }
    });

    // Theme Toggle Logic — multi-layer cinematic transition
    let isAnimating = false;

    const handleToggleClick = (e: MouseEvent) => {
        if (isAnimating) return;
        isAnimating = true;

        const html = document.documentElement;
        const isDark = html.classList.contains("dark");
        const ox = e.clientX;
        const oy = e.clientY;
        const W = window.innerWidth;
        const H = window.innerHeight;

        // Colors for new theme
        const newBg   = isDark ? "#F2F4F7" : "#0A2540";
        const newAccent = isDark ? "#1F6AE1" : "#A9C9FF";

        // ── 1. Button burst: scale + glow ring ──────────────────────
        const btn = e.currentTarget as HTMLElement;
        btn.animate(
            [
                { transform: "scale(1)",    filter: "none" },
                { transform: "scale(1.5)",  filter: `drop-shadow(0 0 12px ${newAccent})` },
                { transform: "scale(0.85)", filter: `drop-shadow(0 0 6px ${newAccent})` },
                { transform: "scale(1)",    filter: "none" },
            ],
            { duration: 500, easing: "cubic-bezier(0.34, 1.56, 0.64, 1)" }
        );

        // ── 2. Canvas with tile-dissolve effect ─────────────────────
        const canvas = document.createElement("canvas");
        canvas.width  = W;
        canvas.height = H;
        canvas.style.cssText = `
            position:fixed; inset:0; z-index:9998;
            pointer-events:none; will-change:transform;
        `;
        document.body.appendChild(canvas);
        const ctx = canvas.getContext("2d")!;

        const TILE = 60;
        const cols = Math.ceil(W / TILE);
        const rows = Math.ceil(H / TILE);

        // Sort tiles by distance from click → ripple order
        const tiles: { cx: number; cy: number; delay: number }[] = [];
        const maxDist = Math.hypot(
            Math.max(ox, W - ox),
            Math.max(oy, H - oy)
        );
        for (let r = 0; r < rows; r++) {
            for (let c = 0; c < cols; c++) {
                const cx = c * TILE + TILE / 2;
                const cy = r * TILE + TILE / 2;
                const dist = Math.hypot(cx - ox, cy - oy);
                tiles.push({ cx, cy, delay: dist / maxDist });
            }
        }

        const WAVE_DURATION = 700; // ms for last tile to finish
        const TILE_ANIM     = 280; // each tile's animation duration
        const startTime     = performance.now();
        let themeApplied    = false;

        function drawFrame(now: number) {
            ctx.clearRect(0, 0, W, H);
            let allDone = true;

            for (const tile of tiles) {
                const elapsed = now - startTime - tile.delay * WAVE_DURATION;
                if (elapsed < 0) { allDone = false; continue; }

                const t = Math.min(elapsed / TILE_ANIM, 1);
                if (t < 1) allDone = false;

                // Easing: ease-in-out cubic
                const ease = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

                // Tile scales up from center, then fades out
                const scale    = ease < 0.6 ? ease / 0.6 : 1;
                const alpha    = ease < 0.6 ? 1 : 1 - (ease - 0.6) / 0.4;
                const tileSize = TILE * scale;

                ctx.save();
                ctx.globalAlpha = alpha;

                // Slight rotation for organic feel
                ctx.translate(tile.cx, tile.cy);
                ctx.rotate(ease * 0.4);
                ctx.translate(-tile.cx, -tile.cy);

                // Draw rounded tile
                const x0 = tile.cx - tileSize / 2;
                const y0 = tile.cy - tileSize / 2;
                const r  = tileSize * 0.22;
                ctx.beginPath();
                ctx.moveTo(x0 + r, y0);
                ctx.lineTo(x0 + tileSize - r, y0);
                ctx.quadraticCurveTo(x0 + tileSize, y0, x0 + tileSize, y0 + r);
                ctx.lineTo(x0 + tileSize, y0 + tileSize - r);
                ctx.quadraticCurveTo(x0 + tileSize, y0 + tileSize, x0 + tileSize - r, y0 + tileSize);
                ctx.lineTo(x0 + r, y0 + tileSize);
                ctx.quadraticCurveTo(x0, y0 + tileSize, x0, y0 + tileSize - r);
                ctx.lineTo(x0, y0 + r);
                ctx.quadraticCurveTo(x0, y0, x0 + r, y0);
                ctx.closePath();
                ctx.fillStyle = newBg;
                ctx.fill();

                ctx.restore();
            }

            // Apply theme when wave hits ~50%
            if (!themeApplied && (now - startTime) > WAVE_DURATION * 0.45) {
                themeApplied = true;
                html.classList.toggle("dark");
                localStorage.setItem("theme", html.classList.contains("dark") ? "dark" : "light");
            }

            if (!allDone) {
                requestAnimationFrame(drawFrame);
            } else {
                canvas.remove();
                isAnimating = false;
            }
        }

        requestAnimationFrame(drawFrame);

        // ── 3. Shockwave ring from click origin ──────────────────────
        for (let i = 0; i < 3; i++) {
            const ring = document.createElement("div");
            ring.style.cssText = `
                position:fixed;
                left:${ox}px; top:${oy}px;
                width:0; height:0;
                border-radius:50%;
                border: 2px solid ${newAccent};
                transform:translate(-50%,-50%);
                z-index:9999;
                pointer-events:none;
                opacity:0.8;
            `;
            document.body.appendChild(ring);
            const delay = i * 80;
            ring.animate(
                [
                    { width: "0px",   height: "0px",   opacity: 0.8, offset: 0 },
                    { width: `${maxDist * 2.2}px`, height: `${maxDist * 2.2}px`, opacity: 0, offset: 1 },
                ],
                { duration: 800, delay, easing: "cubic-bezier(0.0, 0.5, 0.5, 1.0)", fill: "forwards" }
            ).onfinish = () => ring.remove();
        }
    };

    document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);
    document.getElementById("theme-toggle-mobile")?.addEventListener("click", handleToggleClick);

    // ── Language Toggle ────────────────────────────────────────────
    const FLAGS: Record<string, string> = { es: "🇪🇸", en: "🇬🇧", de: "🇩🇪" };

    function openDropdown(dropdown: HTMLElement) {
        dropdown.classList.remove("opacity-0", "pointer-events-none", "scale-95");
        dropdown.classList.add("opacity-100", "scale-100");
    }
    function closeDropdown(dropdown: HTMLElement) {
        dropdown.classList.add("opacity-0", "pointer-events-none", "scale-95");
        dropdown.classList.remove("opacity-100", "scale-100");
    }

    function setupLangMenu(toggleId: string, dropdownId: string, flagId: string, codeId: string, optionClass: string) {
        const toggle = document.getElementById(toggleId);
        const dropdown = document.getElementById(dropdownId);
        const flagEl = document.getElementById(flagId);
        const codeEl = document.getElementById(codeId);
        if (!toggle || !dropdown) return;

        toggle.addEventListener("click", (e) => {
            e.stopPropagation();
            const isOpen = !dropdown.classList.contains("opacity-0");
            if (isOpen) closeDropdown(dropdown);
            else openDropdown(dropdown);
        });

        document.querySelectorAll<HTMLButtonElement>(`.${optionClass}`).forEach(btn => {
            btn.addEventListener("click", () => {
                const lang = btn.dataset.lang as string;
                setLanguage(lang);
                closeDropdown(dropdown);
            });
        });

        document.addEventListener("click", () => closeDropdown(dropdown));
        dropdown.addEventListener("click", e => e.stopPropagation());
    }

    setupLangMenu("lang-toggle", "lang-dropdown", "lang-flag", "lang-code", "lang-option");
    setupLangMenu("lang-toggle-mobile", "lang-dropdown-mobile", "lang-flag-mobile", "lang-code-mobile", "lang-option-mobile");

    function updateLangButtons(lang: string) {
        const flag = FLAGS[lang] ?? "🇪🇸";
        const code = lang.toUpperCase();
        const flagEl = document.getElementById("lang-flag");
        const codeEl = document.getElementById("lang-code");
        const flagMobileEl = document.getElementById("lang-flag-mobile");
        const codeMobileEl = document.getElementById("lang-code-mobile");
        if (flagEl) flagEl.textContent = flag;
        if (codeEl) codeEl.textContent = code;
        if (flagMobileEl) flagMobileEl.textContent = flag;
        if (codeMobileEl) codeMobileEl.textContent = code;
    }

    function setLanguage(lang: string) {
        localStorage.setItem("lang", lang);
        document.documentElement.setAttribute("data-lang", lang);
        updateLangButtons(lang);
        applyTranslations(lang);
    }

    function applyTranslations(lang: string) {
        const t = (window as any).__i18n?.[lang];
        if (!t) return;
        document.querySelectorAll<HTMLElement>("[data-i18n]").forEach(el => {
            const key = el.dataset.i18n!;
            if (t[key] !== undefined) el.textContent = t[key];
        });
        // Handle HTML content nodes
        document.querySelectorAll<HTMLElement>("[data-i18n-html]").forEach(el => {
            const key = el.dataset.i18nHtml!;
            if (t[key] !== undefined) el.innerHTML = t[key];
        });
    }

    // Initialize language on load
    const savedLang = localStorage.getItem("lang") || "es";
    updateLangButtons(savedLang);
    document.documentElement.setAttribute("data-lang", savedLang);

    // Wait for translations to be loaded by the inline script in Layout
    if ((window as any).__i18n) {
        applyTranslations(savedLang);
    }
    window.addEventListener("i18n-ready", () => applyTranslations(savedLang));
</script>
